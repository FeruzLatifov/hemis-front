# Logs
/logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Environment files (SECURITY: Never commit secrets)
.env
.env.*
!.env.example

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Security sensitive files
*.pem
*.key
*.crt
*.p12
*.pfx
credentials.json
secrets.json

# Coverage reports (may contain sensitive paths)
coverage/

# Test/automation artifacts
.playwright-mcp/
playwright-report/
test-results/

# Local export downloads (CSV/XLSX exports land here if dev server is launched
# from repo root — the export uses the browser download flow, so these files
# are user-local artifacts, never source)
*.xlsx
*.csv

# Build info
tsconfig.tsbuildinfo
