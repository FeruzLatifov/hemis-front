{
  "permissions": {
    "allow": [
      "Bash(yarn install:*)",
      "Bash(npm install:*)",
      "Bash(yarn dev:*)",
      "Bash(npm run dev:*)",
      "Bash(yarn build:*)",
      "Bash(npm run build:*)",
      "Bash(yarn preview:*)",
      "Bash(yarn test:*)",
      "Bash(npm run test:*)",
      "Bash(yarn lint:*)",
      "Bash(npm run lint:*)",
      "WebSearch",
      "WebFetch(domain:react.dev)",
      "WebFetch(domain:tailwindcss.com)",
      "WebFetch(domain:ui.shadcn.com)",
      "WebFetch(domain:developer.mozilla.org)",
      "Read(src/**/*)",
      "Read(.env.example)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.local)",
      "Read(secrets/**)",
      "Bash(rm -rf:*)",
      "Bash(rm:*)",
      "Bash(sudo:*)"
    ],
    "ask": ["Bash(git push:*)", "Bash(docker run:*)", "Bash(npm publish:*)", "Bash(yarn publish:*)"]
  },
  "testsEnabled": false,
  "companyAnnouncements": [
    "Remember to use the defined education colour palette (blue, green, purple, gold) with no gradients or glass effects.",
    "Limit accent colours to two per page and include text on buttons even when icons are present.",
    "Base API requests off import.meta.env.VITE_API_URL and never hard‑code endpoints."
  ]
}
